{
  "base_url": "https://opensource-demo.orangehrmlive.com/web/index.php/auth/login",
  "username": {
    "by": "name",
    "value": "username"
  },
  "password": {
    "by": "name",
    "value": "password"
  },
  "login_button": {
    "by": "css",
    "value": "button[type='submit']"
  },
  "error_alert": {
    "by": "css",
    "value": ".oxd-alert-content-text"
  },
  "dashboard_heading": {
    "by": "css",
    "value": "h6.oxd-text--h6"
  },
  "forgot_password": {
    "by": "css",
    "value": ".orangehrm-login-forgot-header"
  },
  "username_required_error": {
    "by": "xpath",
    "value": "//label[text()='Username']/ancestor::div[contains(@class,'oxd-input-group')]//span[contains(@class,'oxd-input-field-error-message')]"
  },
  "password_required_error": {
    "by": "xpath",
    "value": "//label[text()='Password']/ancestor::div[contains(@class,'oxd-input-group')]//span[contains(@class,'oxd-input-field-error-message')]"
  },
  "validation_errors": {
    "by": "css",
    "value": ".oxd-input-field-error-message"
  },
  "login_heading": {
    "by": "css",
    "value": ".orangehrm-login-title"
  },
  "version_text": {
    "by": "css",
    "value": ".orangehrm-copyright"
  }
}
